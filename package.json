{
  "name": "replaceme",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "prebuild": "EXPO_NO_GIT_STATUS=1 expo prebuild --clean",
    "start": "doppler run -- expo start --dev-client",
    "start:clear": "doppler run -- expo start --dev-client --clear",
    "start:local": "expo start --dev-client",
    "start:local:clear": "expo start --dev-client --clear",
    "android": "doppler run -- expo run:android",
    "ios": "doppler run -- expo run:ios",
    "runios": "doppler run -- expo run:ios",
    "web": "doppler run -- expo start --web",
    "lint": "expo lint",
    "test:search": "node scripts/search-test.mjs",
    "format": "biome check --write",
    "postinstall": "patch-package",
    "generate-db-types": "doppler run -- npx supabase gen types typescript --project-id \"$SUPABASE_PROJECT_ID\" --schema public > types/database.types.ts",
    "deploy:recognize-food": "npx supabase functions deploy recognize-food --no-verify-jwt",
    "supabase:link": "npx supabase link",
    "supabase:login": "npx supabase login",
    "build:production": "doppler -c prd run -- eas build --output dist/ios-production.ipa --profile production --platform ios --local",
    "submit": "doppler -c prd run -- eas submit --platform ios --path dist/ios-production.ipa"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "^11.5.2",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@rn-primitives/label": "^1.2.0",
    "@rn-primitives/slot": "^1.2.0",
    "@sentry/react-native": "^7.8.0",
    "@supabase/supabase-js": "^2.88.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "expo": "~54.0.30",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "^6.0.20",
    "expo-file-system": "^19.0.21",
    "expo-font": "~14.0.10",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-secure-store": "^15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "lucide-react": "^0.563.0",
    "lucide-react-native": "^0.562.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-purchases": "^9.11.2",
    "react-native-purchases-ui": "^9.11.2",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "nativewind": "^4.2.1",
    "patch-package": "^8.0.0",
    "tailwindcss": "^3.4.18",
    "typescript": "~5.9.2"
  },
  "private": true,
  "packageManager": "pnpm@10.25.0",
  "pnpm": {
    "overrides": {
      "ws": "^8.18.0"
    }
  }
}
