# Copy to `.env` for local runs (e.g. `pnpm run start:local`).
# With `pnpm start`, Doppler may inject vars — same names; metro.config.js merges missing keys from `.env`.

# ── Supabase (Settings → API) ──
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# If your tooling only provides the legacy name:
# EXPO_PUBLIC_SUPABASE_ANON_KEY_=

# ── OpenAI (Scan food / meal vision from the app) ──
# Key is in the client bundle — dev/TestFlight only; use Edge secrets in production.
EXPO_PUBLIC_OPENAI_API_KEY=
EXPO_PUBLIC_OPENAI_VISION_MODEL=gpt-4o-mini
# EXPO_PUBLIC_OPENAI_VISION_FALLBACK=1

# ── RevenueCat ──
EXPO_PUBLIC_REVENUECAT_API_KEY=
# EXPO_PUBLIC_REVENUECAT_OFFERING_ID=
# EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=

# Dev only: Pro without a purchase (ignored when __DEV__ is false). Never set in App Store builds.
# EXPO_PUBLIC_DEV_UNLOCK_PRO=1

# ── Supabase Edge only (not in this file) ──
# npx supabase secrets set OPENAI_API_KEY=sk-...
# npx supabase secrets set OPENAI_MODEL=gpt-4o-mini
# pnpm run deploy:recognize-food
