# Copy to ".env" for local runs without Doppler (e.g. pnpm run start:local).
# If you use `pnpm start`, secrets often come from Doppler — same variable names.
# Supabase dashboard: https://supabase.com/dashboard → Project → Settings → API

# ── Required for meal vision via Supabase (recommended; key stays off the device) ──
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# On Supabase only (CLI or Dashboard → Edge Functions → Secrets), not in this file:
#   OPENAI_API_KEY=sk-...          # used by recognize-food Edge Function
# Optional:
#   OPENAI_MODEL=gpt-4o-mini       # default if unset
# Then: pnpm run deploy:recognize-food

# ── Meal photo scan (Scan food): OpenAI from the app ──
# Set your key here so "Scan food" uses your OpenAI credits directly (runs before Edge when this is set).
# Key is in the client bundle — fine for dev/TestFlight; avoid shipping sk- keys in public store builds.
EXPO_PUBLIC_OPENAI_API_KEY=
EXPO_PUBLIC_OPENAI_VISION_MODEL=gpt-4o-mini
# EXPO_PUBLIC_OPENAI_VISION_FALLBACK=1   # if Edge fails *and* you did not set a client key above (rare)
